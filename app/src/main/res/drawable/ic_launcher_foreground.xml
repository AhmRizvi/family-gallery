<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Golden Camera Icon centered and scaled to fit the 72dp safe area perfectly -->
    <group
        android:pivotX="54"
        android:pivotY="54">

        <!-- Camera Body -->
        <path
            android:pathData="M 32,42 C 32,39.8 33.8,38 36,38 L 46,38 L 49.5,33 L 58.5,33 L 62,38 L 72,38 C 74.2,38 76,39.8 76,42 L 76,68 C 76,70.2 74.2,72 72,72 L 36,72 C 33.8,72 32,70.2 32,68 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="32"
                    android:startY="33"
                    android:endX="76"
                    android:endY="72">
                    <item android:offset="0.0" android:color="#FFE8A1" />
                    <item android:offset="0.5" android:color="#D4AF37" />
                    <item android:offset="1.0" android:color="#AA7C11" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Lens Outer Ring (Thin Black shadow separator to add depth) -->
        <path
            android:pathData="M 54,55 m -12,0 a 12,12 0 1,1 24,0 a 12,12 0 1,1 -24,0"
            android:fillColor="#000000" />

        <!-- Lens Inner Ring (Golden Gradient) -->
        <path
            android:pathData="M 54,55 m -10.5,0 a 10.5,10.5 0 1,1 21,0 a 10.5,10.5 0 1,1 -21,0">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="43.5"
                    android:startY="44.5"
                    android:endX="64.5"
                    android:endY="65.5">
                    <item android:offset="0.0" android:color="#FFE8A1" />
                    <item android:offset="0.5" android:color="#D4AF37" />
                    <item android:offset="1.0" android:color="#AA7C11" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Lens Aperture/Glass (Dark slate to resemble glass reflection) -->
        <path
            android:pathData="M 54,55 m -7.5,0 a 7.5,7.5 0 1,1 15,0 a 7.5,7.5 0 1,1 -15,0"
            android:fillColor="#15151A" />

        <!-- Lens Reflection Highlight (Polished white glare) -->
        <path
            android:pathData="M 51.5,52.5 m -1.5,0 a 1.5,1.5 0 1,1 3,0 a 1.5,1.5 0 1,1 -3,0"
            android:fillColor="#FFFFFFFF" />

        <!-- Camera Flash / Red-eye dot (Small gold reflection) -->
        <path
            android:pathData="M 67,45 m -1.5,0 a 1.5,1.5 0 1,1 3,0 a 1.5,1.5 0 1,1 -3,0"
            android:fillColor="#FFE8A1" />

    </group>
</vector>
